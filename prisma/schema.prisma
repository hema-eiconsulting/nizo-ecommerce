generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  phone         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(CUSTOMER)
  lastLogin     DateTime?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  addresses     Address[]
  orders        Order[]
  cart          Cart?
  searchHistory SearchHistory[]
  wishlist      Product[] @relation("UserWishlist")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpVerification {
  id        String   @id @default(cuid())
  phone     String   @unique
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String  @id @default(uuid())
  cartId    String
  productId String
  size      Size
  quantity  Int
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model SearchHistory {
  id        String   @id @default(uuid())
  userId    String
  query     String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Address {
  id        String  @id @default(uuid())
  userId    String
  name      String
  street    String
  city      String
  state     String
  pinCode   String
  country   String  @default("India")
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id])
}

model Product {
  id           String        @id @default(uuid())
  name         String
  description  String
  price        Float
  gender       Gender
  category     Category
  isActive     Boolean       @default(true)
  images       String[]
  colors       String[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  orderItems   OrderItem[]
  sizes        ProductSize[]
  wishlistedBy User[]        @relation("UserWishlist")
  cartItems    CartItem[]
}

model ProductSize {
  id        String  @id @default(uuid())
  productId String
  size      Size
  stock     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, size])
}

model Order {
  id                String        @id @default(uuid())
  userId            String?
  totalAmount       Float
  shippingCost      Float         @default(0)
  taxAmount         Float         @default(0)
  status            OrderStatus   @default(PROCESSING)
  paymentMethod     PaymentMethod
  paymentStatus     PaymentStatus @default(PENDING)
  razorpayOrderId   String?
  razorpayPaymentId String?
  trackingNumber    String?
  courierName       String?
  codCollected      Boolean       @default(false)
  shippingAddress   String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User?         @relation(fields: [userId], references: [id])
  items             OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  size      Size
  quantity  Int
  price     Float
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

enum Role {
  CUSTOMER
  ADMIN
}

enum Gender {
  MEN
  WOMEN
  UNISEX
}

enum Category {
  T_SHIRTS
  SHIRTS
  PANTS
  FOOTWEAR
  ACCESSORIES
  TOPS
  DRESSES
  BOTTOMS
  TROUSERS
  JACKETS
}

enum Size {
  XS
  S
  M
  L
  XL
  XXL
  FREE
}

enum OrderStatus {
  CONFIRMED
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  WALLET
  COD
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
